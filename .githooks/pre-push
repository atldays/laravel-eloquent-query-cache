#!/bin/sh

set -eu

if ! command -v docker >/dev/null 2>&1; then
    echo "Docker is required to run tests before push."
    exit 1
fi

echo "Running test suite before push..."

if [ ! -x vendor/bin/phpunit ]; then
    echo "vendor/bin/phpunit not found. Run composer install/update first."
    exit 1
fi

docker run --rm \
    -v "$PWD:/app" \
    -w /app \
    composer:2 sh -lc 'composer test'
