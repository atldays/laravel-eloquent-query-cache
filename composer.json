{
    "name": "atldays/laravel-eloquent-query-cache",
    "description": "Adding cache on your Laravel Eloquent queries' results is now a breeze.",
    "keywords": [
        "laravel",
        "caching",
        "eloquent",
        "remember",
        "query",
        "sql",
        "atldays"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/atldays/laravel-eloquent-query-cache",
    "type": "library",
    "authors": [
        {
            "name": "Anjey Tsibylskij",
            "homepage": "https://github.com/atldays",
            "role": "Developer"
        }
    ],
    "require": {
        "illuminate/cache": "^10.5|^11.33|^12.0",
        "illuminate/database": "^10.5|^11.33|^12.0",
        "illuminate/support": "^10.5|^11.33|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Atldays\\QueryCache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atldays\\QueryCache\\Test\\": "tests"
        }
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "test": "vendor/bin/phpunit"
    },
    "require-dev": {
        "laravel/pint": "^1.21",
        "laravel/legacy-factories": "^1.4",
        "livewire/livewire": "dev-main",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.1.1|^9|^10.0",
        "phpunit/phpunit": "^9.5.25|^10|^11"
    },
    "config": {
        "sort-packages": true
    },
    "prefer-stable": true,
    "minimum-stability": "dev"
}
